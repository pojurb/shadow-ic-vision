DB_PATH=../jp-invest-data/db.sqlite
LLM_PROVIDER_TYPE=mock
OLLAMA_API_KEY=your-api-key-here
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_API_URL=https://ollama.com/api
RESEARCH_SOURCE_MODE=mock
# Required only when RESEARCH_SOURCE_MODE=live. SEC requires an app name and contact email.
SEC_USER_AGENT=JP Invest your-email@example.com
# Optional; defaults beside DB_PATH and must remain outside the repository.
SOURCE_SNAPSHOT_DIR=../jp-invest-data/source-snapshots
# Optional; defaults to ignored logs/outbound.log.
OUTBOUND_LOG_PATH=logs/outbound.log
# Required for /api/internal/research/cron. Send as Authorization: Bearer <secret>.
RESEARCH_CRON_SECRET=replace-with-a-long-random-secret
# Displayed schedule metadata; the local Windows task is the scheduling authority.
RESEARCH_REFRESH_SCHEDULE=0 8 * * *
# JSON map of tracked tickers to trusted official investor-relations pages.
ISSUER_SOURCE_URLS={"BBRI":"https://www.ir-bri.com/financials.html"}
