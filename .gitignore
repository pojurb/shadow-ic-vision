# === SENSITIVE DATA (never commit real financial data) ===
data/Portfolio_Master_State.md
.env
.env.*
!.env.example
CLAUDE.local.md

# === GENERATED OUTPUTS (regenerable by AI) ===
outputs/living_thesis/*.md
!outputs/living_thesis/_example_BBCA.md
app/.next-qa-*

# === USER-UPLOADED RAW DATA ===
inputs/stocks/*.csv
inputs/startups/*.csv
inputs/conventional_biz/*.csv
# Keep sample data as part of the template
!inputs/stocks/_sample_BBCA.csv
!inputs/startups/_sample_fintech.csv
!inputs/conventional_biz/_sample_cafe.csv

# === OS ARTIFACTS ===
.DS_Store
Thumbs.db
Desktop.ini
.tmp-*

# === NODE ===
node_modules/
.next/
out/
build/
test-results/
playwright-report/
.tmp-e2e/
docs/evals/M001/*.local.json
tsconfig.tsbuildinfo

# === DATABASE & LOGS ===
*.sqlite
*.sqlite-journal
logs/

# Keep local screenshots in issues/ but do not track images
issues/*
!issues/.gitkeep
