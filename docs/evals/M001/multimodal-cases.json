    {
      "id": "MM-016",
      "name": "XBRL Fact and Deterministic Margin Calculation",
      "category": "Structured Financial Data",
      "risk_id": "R-017",
      "acceptance_criterion": "AC-M001-MM-02",
      "held_out": true,
      "input": {
        "fixture_spec": {
          "format": "xbrl",
          "content_kind": "structured_fact",
          "source_url": "https://example.invalid/fixtures/pltr-q1-2026.xbrl",
          "facts": [
            {"concept": "Revenue", "value": 1000, "unit": "USD millions", "period": "2026-Q1"},
            {"concept": "CostOfRevenue", "value": 187, "unit": "USD millions", "period": "2026-Q1"}
          ]
        },
        "requested_metric": "gross_margin"
      },
      "expected": {
        "value": 0.813,
        "display_value": "81.3%",
        "source_format": "xbrl",
        "content_kind": "structured_fact",
        "verification_status": "derived",
        "extraction_method": "deterministic_calculation",
        "formula": "(Revenue - CostOfRevenue) / Revenue",
        "input_concepts": ["Revenue", "CostOfRevenue"]
      },
      "rubric": {
        "calculation_inputs_retained": true,
        "failure_if_model_only_calculation": true,
        "failure_if_marked_exact_verified": true
