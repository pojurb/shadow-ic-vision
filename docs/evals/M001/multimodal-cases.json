          "format": "pdf",
          "source_variant": "text_layer",
          "content_kind": "text",
          "source_url": "https://example.invalid/fixtures/300-page-filing.pdf",
          "page_count": 300,
          "generated_default_page_text": "Synthetic filler page {page}.",
          "overrides": [
            {"page": 237, "text": "The company reduced its 2026 capacity target from 80% to 62%."}
          ]
        },
        "query": "What changed in the 2026 capacity target?"
      },
      "expected": {
        "selected_page": 237,
        "selected_text": "The company reduced its 2026 capacity target from 80% to 62%.",
        "chunk_provenance_required": true,
        "document_hash_required": true,
        "missing_context_claimed": false
      },
      "rubric": {
        "failure_if_page_lost": true,
        "failure_if_context_invented": true
      }
