{
  "milestone": "M1",
  "testCases": [
    {
      "id": "M1_TC_01_Insert_And_Traverse",
      "description": "Verify successful insertion and traversal of basic GraphNodes and GraphEdges.",
      "input": {
        "nodes": [
          {
            "id": "node-AAPL",
            "type": "Asset",
            "properties": {
              "name": "Apple Inc.",
              "ticker": "AAPL"
            }
          },
          {
            "id": "node-iPhoneDemand",
            "type": "Assumption",
            "properties": {
              "statement": "iPhone 18 demand grows by 10% YoY.",
              "state": "valid"
            }
          }
        ],
        "edges": [
          {
            "id": "edge-AAPL-iPhone",
            "source": "node-AAPL",
            "target": "node-iPhoneDemand",
            "relationship": "DEPENDS_ON",
            "weight": 1.0
          }
        ]
      },
      "expected": {
        "nodeCount": 2,
        "edgeCount": 1,
        "connectedNodes": ["node-iPhoneDemand"]
      }
    },
    {
      "id": "M1_TC_02_Cycle_Detection_Rejected",
      "description": "Verify that introducing circular dependencies raises an validation error.",
      "input": {
        "nodes": [
          {
            "id": "node-A",
            "type": "Assumption",
            "properties": { "statement": "Assumption A" }
          },
          {
            "id": "node-B",
            "type": "Assumption",
            "properties": { "statement": "Assumption B" }
          }
        ],
        "edges": [
          {
            "id": "edge-A-to-B",
            "source": "node-A",
            "target": "node-B",
            "relationship": "DEPENDS_ON",
            "weight": 1.0
          },
          {
            "id": "edge-B-to-A",
            "source": "node-B",
            "target": "node-A",
            "relationship": "DEPENDS_ON",
            "weight": 1.0
          }
        ]
      },
      "expected": {
        "shouldFail": true,
        "errorMessageContains": "circular dependency"
      }
    },
    {
      "id": "M1_TC_03_Schema_Validation_Rejection",
      "description": "Verify that nodes with missing or incorrect structural fields are rejected.",
      "input": {
        "nodes": [
          {
            "id": "node-Invalid",
            "type": "NotARealType",
            "properties": {}
          }
        ],
        "edges": []
      },
      "expected": {
        "shouldFail": true,
        "errorMessageContains": "invalid"
      }
    },
    {
      "id": "M1_TC_04_CRDT_Concurrent_Conflict_Resolution",
      "description": "Verify that two parallel edits to the same node resolve deterministically.",
      "input": {
        "nodeId": "node-Conflict",
        "initialProperties": {
          "name": "Original Name",
          "val": 100
        },
        "clientAChange": {
          "properties": { "name": "Name from Client A" },
          "timestamp": 1719870000000
        },
        "clientBChange": {
          "properties": { "name": "Name from Client B" },
          "timestamp": 1719870001000
        }
      },
      "expected": {
        "finalProperties": {
          "name": "Name from Client B",
          "val": 100
        }
      }
    }
  ]
}
